{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPkgs": ["python3", "pip"]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "envVars": {
      "JWT_SECRET_KEY": {
        "generator": "SECRET"
      },
      "DEBUG": "false"
    }
  }
}
