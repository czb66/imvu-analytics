# 环境变量配置文件
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./data/marketing_analytics.db

# ==================== 邮件配置 ====================
# Gmail 示例
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True

# 收件人（多个用逗号分隔）
EMAIL_TO=team@example.com,manager@example.com

# ==================== 报告配置 ====================
# 定时任务时间（UTC时间）
REPORT_CRON_HOUR=1
REPORT_CRON_MINUTE=0

# ==================== 分析阈值 ====================
# 异常检测阈值（标准差倍数）
SALES_ANOMALY_THRESHOLD=2.0

# 高利润产品利润率阈值
HIGH_PROFIT_MARGIN=0.3

# 低转化率阈值
LOW_CONVERSION_THRESHOLD=0.01
